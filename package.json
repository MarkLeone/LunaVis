{
  "name": "lunavis",
  "version": "0.1.0",
  "type": "module",
  "scripts": {
    "dev": "vite",
    "build": "npm run download-assets && tsc && vite build",
    "preview": "vite preview",
    "download-assets": "bash scripts/download-assets.sh",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:smoke": "playwright test --config=tests/e2e/playwright.config.cjs tests/e2e/smoke.spec.cjs",
    "test:e2e": "playwright test --config=tests/e2e/playwright.config.cjs"
  },
  "dependencies": {
    "@loaders.gl/core": "^4.3.4",
    "@loaders.gl/gltf": "^4.3.4",
    "@tweakpane/core": "^2.0.5",
    "stats.js": "^0.17.0",
    "tweakpane": "^4.0.5",
    "wgpu-matrix": "^3.4.0"
  },
  "devDependencies": {
    "@playwright/test": "^1.58.0",
    "@types/stats.js": "^0.17.4",
    "@webgpu/types": "^0.1.54",
    "typescript": "^5.7.3",
    "vite": "^6.0.7",
    "vitest": "^3.0.4"
  }
}
